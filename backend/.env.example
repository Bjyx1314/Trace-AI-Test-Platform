ANTHROPIC_API_KEY=
FEISHU_WEBHOOK_URL=
DATABASE_URL=postgresql+asyncpg://testplatform:testplatform@localhost:5432/test_platform
JWT_SECRET=replace-with-a-long-random-value
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
MOCK_MODE=false
# 是否允许"失败回退/占位 mock"——仅本地开发置 true；服务器真实环境必须 false(失败即报错，绝不产生 mock 数据)
ALLOW_MOCK=false

# ── AI 调用层（多 provider 可配置；详见 docs/AI-provider配置说明.md）──
# AI_PROVIDER: anthropic | openai | claude_cli(订阅方式)
AI_PROVIDER=anthropic
# 通用 Key；留空时回退 ANTHROPIC_API_KEY（claude_cli 订阅方式不需要 Key）
AI_API_KEY=
# 自定义/中转地址（anthropic、openai 适用），留空走官方
AI_BASE_URL=
# 模型名（必填；平台不提供默认模型）
AI_MODEL=
# 订阅方式所用的 claude CLI 路径
CLAUDE_CLI_PATH=claude

# 飞书自建应用（Bitable需求同步 + 缺陷自动建单），留空则走mock数据
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_REQUIREMENTS_TABLE_ID=
FEISHU_DEFECTS_TABLE_ID=

# 可选外部 SSO / 任务系统。不使用时保持为空。
EXTERNAL_TASK_API_URL=
EXTERNAL_TASK_API_KEY=

# 可选外部自动化框架仓库。留空时不会写入框架仓库种子数据。
FRAMEWORK_WEB_GIT_URL=
FRAMEWORK_API_GIT_URL=
FRAMEWORK_GIT_BRANCH=main
# JSON 格式，按端配置外部框架 project/web/auth_type/flow_class/smoke 等信息。
FRAMEWORK_PLATFORM_MAP_JSON={}
FRAMEWORK_LOGIN_SMOKE=

# ── Sonic 云真机（远程真机执行；开启后执行弹框可选「远程真机」，无本地真机也能跑 App）──
# 注意：backend 容器需装 adb + uiautomator2，且能网络直连 Sonic agent 主机的 SAS 端口段
SONIC_ENABLED=false
SONIC_BASE_URL=http://sonic-host:3000/api/controller
# 账号密码登录换 token（推荐）；或直接配 SONIC_TOKEN(generateToken 生成的长效 token，配了则优先)
SONIC_USERNAME=
SONIC_PASSWORD=
SONIC_TOKEN=
# 占用设备时开的远程 adb(SAS)端口范围
SONIC_SAS_PORT_MIN=30000
SONIC_SAS_PORT_MAX=30100
